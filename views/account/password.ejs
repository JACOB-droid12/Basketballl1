<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Change Password</title>
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <header class="mockup-topbar">
      <h1>Admin Dashboard</h1>
    </header>
    <div class="app-shell">
      <%- include("../partials/navigation", { active }) %>
      <main class="workspace mockup-workspace">
        <section class="account-panel office-panel" aria-labelledby="change-password-title">
          <h1 id="change-password-title">Change Password</h1>

          <% if (currentUser && currentUser.role === "ADMIN") { %>
            <div class="account-toolbar">
              <a class="button secondary" href="/account">Back to Account Management</a>
            </div>
          <% } %>

          <% if (successMessage) { %>
            <div class="alert success"><%= successMessage %></div>
          <% } %>

          <% if (errorMessage) { %>
            <div class="alert"><%= errorMessage %></div>
          <% } %>

          <form class="account-form" method="post" action="/account/password" novalidate>
            <label>
              <span>Current Password</span>
              <input type="password" name="currentPassword" required autocomplete="current-password">
              <% if (errors.currentPassword) { %><small><%= errors.currentPassword %></small><% } %>
            </label>

            <label>
              <span>New Password</span>
              <input type="password" name="newPassword" required autocomplete="new-password">
              <% if (errors.newPassword) { %><small><%= errors.newPassword %></small><% } %>
            </label>

            <label>
              <span>Confirm Password</span>
              <input type="password" name="confirmPassword" required autocomplete="new-password">
              <% if (errors.confirmPassword) { %><small><%= errors.confirmPassword %></small><% } %>
            </label>

            <button class="button account-save-button" type="submit">Save Password</button>
          </form>
        </section>
      </main>
    </div>
  </body>
</html>
