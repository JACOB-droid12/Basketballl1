<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Account Management</title>
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <header class="mockup-topbar">
      <h1>Admin Dashboard</h1>
    </header>
    <div class="app-shell">
      <%- include("../partials/navigation", { active }) %>
      <main class="workspace mockup-workspace">
        <section class="account-panel account-list-panel office-panel" aria-labelledby="account-title">
          <h1 id="account-title">Account Management</h1>
          <div class="account-toolbar">
            <a class="button account-create-button" href="/account/create">Create Account</a>
          </div>

          <% if (errorMessage) { %>
            <div class="alert"><%= errorMessage %></div>
          <% } %>

          <div class="table-wrap account-table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Full Name</th>
                  <th>Username</th>
                  <th>Role</th>
                  <th>Status</th>
                  <th>Created</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (users.length === 0) { %>
                  <tr>
                    <td colspan="6">No user accounts found.</td>
                  </tr>
                <% } %>
                <% users.forEach((user) => { %>
                  <tr>
                    <td><%= user.fullName %></td>
                    <td><%= user.username %></td>
                    <td><%= user.role %></td>
                    <td><span class="status <%= user.accountStatus.toLowerCase() %>"><%= user.accountStatus %></span></td>
                    <td><%= user.createdAt %></td>
                    <td class="actions">
                      <% if (Number(user.userId) === Number(currentUserId)) { %>
                        <span class="muted-action">Current account</span>
                      <% } else { %>
                        <form method="post" action="/account/<%= user.userId %>/status">
                          <% const nextStatus = user.accountStatus === "ACTIVE" ? "INACTIVE" : "ACTIVE"; %>
                          <input type="hidden" name="accountStatus" value="<%= nextStatus %>">
                          <button type="submit"><%= nextStatus === "ACTIVE" ? "Reactivate" : "Deactivate" %></button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
