<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Activity Logs</title>
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <header class="mockup-topbar">
      <h1>Activity Logs</h1>
    </header>
    <div class="app-shell">
      <%- include("../partials/navigation", { active }) %>
      <main class="workspace mockup-workspace">
        <header class="page-header">
          <div>
            <p>Barangay Sto. Niño, Parañaque City</p>
            <h1>Reservation Activity Monitoring</h1>
          </div>
          <a class="button secondary" href="/reservations">Reservation Records</a>
        </header>

        <% if (errorMessage) { %>
          <div class="alert"><%= errorMessage %></div>
        <% } %>

        <section class="office-panel reservation-shell">
          <form class="filter-bar activity-filter-bar" method="get" action="/activity-logs">
            <label>
              <span>Date</span>
              <input type="date" name="date" value="<%= filters.date || '' %>">
            </label>
            <label>
              <span>Action</span>
              <input type="search" name="action" value="<%= filters.action || '' %>" placeholder="CREATE_RESERVATION">
            </label>
            <label>
              <span>User / Details</span>
              <input type="search" name="search" value="<%= filters.search || '' %>">
            </label>
            <button class="button secondary" type="submit">Filter</button>
          </form>

          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Date / Time</th>
                  <th>Action</th>
                  <th>Encoded By</th>
                  <th>Reservation</th>
                  <th>Details</th>
                </tr>
              </thead>
              <tbody>
                <% if (logs.length === 0) { %>
                  <tr>
                    <td colspan="5">No activity log records found.</td>
                  </tr>
                <% } %>
                <% logs.forEach((log) => { %>
                  <tr>
                    <td><%= log.createdAt %></td>
                    <td><span class="status log-action"><%= log.action %></span></td>
                    <td><%= log.userName %></td>
                    <td>
                      <% if (log.reservationId) { %>
                        <a class="record-link" href="/reservations/<%= log.reservationId %>">
                          <%= log.reservationDate %> <%= log.reservationStartTime %> - <%= log.reservationEndTime %>
                        </a>
                      <% } else { %>
                        No reservation linked
                      <% } %>
                    </td>
                    <td><%= log.details %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
