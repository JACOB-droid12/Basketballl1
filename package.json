{
  "name": "barangay-basketball-court-scheduler",
  "version": "0.1.0",
  "private": true,
  "description": "Offline barangay-office basketball court scheduling system for Barangay Sto. Niño, Parañaque City.",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node scripts/run-tests.mjs",
    "bundle:offline": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-offline-bundle.ps1",
    "setup:barangay": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-barangay-office.ps1",
    "setup:env": "node scripts/setup-env.mjs",
    "verify:sql": "node scripts/verify-sql-static.mjs",
    "verify:prereqs": "node scripts/verify-prereqs.mjs",
    "verify:runtime-package": "node scripts/verify-runtime-package.mjs",
    "verify:foundation": "node scripts/verify-foundation.mjs",
    "verify:bundle": "node scripts/verify-offline-bundle.mjs",
    "verify:bundle:strict": "node scripts/verify-offline-bundle.mjs --strict",
    "verify:offline-runtime": "node scripts/verify-offline-runtime.mjs",
    "verify:mysql": "node scripts/verify-mysql.mjs",
    "verify:stress": "node scripts/verify-deployment-stress.mjs",
    "check:database": "node scripts/check-runtime-database.mjs",
    "verify:ui": "node scripts/verify-ui-smoke.mjs",
    "backup:mysql": "node scripts/backup-mysql.mjs",
    "restore:mysql": "node scripts/restore-mysql.mjs",
    "frontend:dev": "vite --host 127.0.0.1 --config client/vite.config.js",
    "frontend:build": "vite build --config client/vite.config.js",
    "frontend:preview": "vite preview --host 127.0.0.1 --config client/vite.config.js",
    "verify:react-build": "node scripts/verify-react-build.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "mysql2": "^3.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "jsdom": "^25.0.0",
    "tsx": "^4.0.0"
  }
}
